{
  "name": "@rx-twitter/dashboard",
  "version": "1.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .githooks && chmod +x .githooks/pre-commit || true",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@rx-twitter/shared": "^0.2.0",
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^11.0.0",
    "@astrojs/preact": "^6.0.0",
    "arctic": "^3.0.0",
    "astro": "^7.0.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.2",
    "preact": "^10.24.3",
    "typescript": "^5.7.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@vitest/coverage-v8": "4.1.2",
    "drizzle-kit": "0.31.10",
    "oxfmt": "0.56.0",
    "oxlint": "1.58.0",
    "vitest": "4.1.2"
  }
}
