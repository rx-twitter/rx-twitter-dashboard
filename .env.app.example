# Dashboard Application Environment Variables
# Docker 環境: cp .env.app.example .env.app
# ローカル開発: cp .env.app.example .env

# Discord OAuth2
DISCORD_OAUTH2_CLIENT_ID=your_client_id
DISCORD_OAUTH2_CLIENT_SECRET=your_client_secret
DISCORD_OAUTH2_REDIRECT_URI=https://yourdomain.com/api/auth/discord/callback

# Session & Encryption
SESSION_SECRET=generate_with_openssl_rand_base64_32
ENCRYPTION_SALT=generate_with_openssl_rand_base64_32

# Database
DATABASE_URL=file:./data/dashboard.db

# Redis（Docker では compose.yml の environment ブロックで上書きされる）
REDIS_URL=redis://redis:6379

# Optional: Config cleanup
ORPHAN_CONFIG_RETENTION_DAYS=30

# Audit log retention (default: 90 days)
AUDIT_LOG_RETENTION_DAYS=90
