#!/bin/sh
# schema.ts が変更に含まれる場合、db:generate を自動実行してステージングに追加する

SCHEMA_FILE="src/lib/db/schema.ts"

if git diff --cached --name-only | grep -q "$SCHEMA_FILE"; then
  echo "[pre-commit] $SCHEMA_FILE changed. Running db:generate..."
  npm run db:generate
  if [ $? -ne 0 ]; then
    echo "[pre-commit] db:generate failed. Aborting commit."
    exit 1
  fi
  git add drizzle/
  echo "[pre-commit] drizzle/ staged."
fi
